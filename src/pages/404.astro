---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Sidan hittades inte — Brutna Löften">
  <section class="flex flex-col items-center justify-center py-24 px-4 text-center">
    <h1 class="text-4xl font-bold mb-4">404</h1>
    <p class="text-muted-foreground mb-6">Sidan du letar efter finns inte.</p>
    <a
      href="./"
      class="inline-flex h-10 items-center justify-center rounded-md bg-primary px-6 text-sm font-medium text-primary-foreground shadow transition-colors hover:bg-primary/90"
    >
      Tillbaka till startsidan
    </a>
  </section>
</Layout>
